// Configuration - modules-center
    
    "modules-center": [
        "clock",
    ],

// Configuration - modules-right

    "modules-right": [
        "temperature",
        "idle_inhibitor",
        "bluetooth",
        "pulseaudio",
        "battery",
        "custom/power"
    ],

    "temperature": {
			"hwmon-path": "/home/dariobf/.local/devices/cpu/temp1_input",
			"critical-threshold": 80,
			"interval": 2,
			"format": "´ïë {temperatureC}┬░C",
			"on-click": "kitty -e btop"
		},

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        },
        "tooltip-format-activated": "Idle Inhibitor Activated",
        "tooltip-format-deactivated": "Idle Inhibitor Deactivated"
    },

    "bluetooth": {
      "format": "´èö",
      "format-disabled": "¾░é▓",
      "format-connected": "´èö",
