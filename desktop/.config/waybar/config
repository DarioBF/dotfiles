    "clock": {
      "format": "{:%A %d, %H:%M}",
      "tooltip": false,
      "on-click": "swaymsg exec 'kitty --class=Calendar --override font_size=9 -e bash -c \"calcure; read -n 1 -s\"'"
    },

    "custom/power": {
