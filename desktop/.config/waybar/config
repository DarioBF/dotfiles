      "on-click": "swaymsg exec 'kitty --class=Bluetooth --override font_size=9 -e bash -c \"bluetuith; read -n 1 -s\"'"
    },

    "pulseaudio": {
        "scroll-step": 2,
        "format": "{icon} {volume}%",
        "format-muted":"¾░Øş muted",
        "format-icons": {
            "headphones": "´ÇÑ",
